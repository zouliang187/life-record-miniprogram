.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(25, 40, 70, 0.06);
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.done {
  background: #e8f4ff;
  color: #1677ff;
}

.todo {
  background: #f3f4f8;
  color: #79808f;
}

.summary {
  color: #556070;
  margin: 18rpx 0;
  font-size: 26rpx;
  min-height: 36rpx;
}

.action {
  background: #1677ff !important;
  color: #fff !important;
  border-radius: 12rpx;
  margin: 0;
  padding: 0 30rpx;
  line-height: 56rpx;
  height: 56rpx;
  font-size: 24rpx;
}
