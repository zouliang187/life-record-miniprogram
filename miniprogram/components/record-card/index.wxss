.record-card {
  align-items: center;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-left: 0 solid transparent;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 36rpx rgba(92, 106, 96, 0.06);
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  min-height: 132rpx;
  padding: 24rpx;
}

.left {
  align-items: center;
  display: flex;
  min-width: 0;
}

.icon {
  align-items: center;
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.12);
  border-radius: 16rpx;
  display: flex;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
  height: 72rpx;
  justify-content: center;
  margin-right: 20rpx;
  width: 72rpx;
}

.content {
  min-width: 0;
}

.title {
  color: #26312b;
  font-size: 30rpx;
  font-weight: 800;
}

.detail {
  color: #8d9a92;
  font-size: 24rpx;
  margin-top: 6rpx;
  max-width: 390rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  border-radius: 999rpx;
  flex-shrink: 0;
  font-size: 23rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
}

.done {
  background: #eef7f1;
  color: #5f9573;
}

.todo {
  background: #fff8ec;
  color: #9b8141;
}
