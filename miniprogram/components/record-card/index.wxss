.record-card {
  align-items: center;
  background: #ffffff;
  border-left: 8rpx solid #07c160;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 36, 48, 0.06);
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  min-height: 132rpx;
  padding: 24rpx;
}

.left {
  align-items: center;
  display: flex;
  min-width: 0;
}

.icon {
  align-items: center;
  border-radius: 8rpx;
  color: #ffffff;
  display: flex;
  flex-shrink: 0;
  font-size: 34rpx;
  height: 72rpx;
  justify-content: center;
  margin-right: 20rpx;
  width: 72rpx;
}

.content {
  min-width: 0;
}

.title {
  color: #1f2430;
  font-size: 31rpx;
  font-weight: 700;
}

.detail {
  color: #7a8190;
  font-size: 25rpx;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 390rpx;
}

.status {
  border-radius: 8rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
}

.done {
  background: #e9f8ef;
  color: #07c160;
}

.todo {
  background: #fff0ec;
  color: #ee0a24;
}
