.chart {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-shadow: 0 14rpx 36rpx rgba(17, 19, 24, 0.06);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.chart-title {
  color: #111318;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 26rpx;
}

.bar-chart {
  align-items: flex-end;
  display: flex;
  height: 320rpx;
  justify-content: space-between;
}

.bar-item {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 100%;
  justify-content: flex-end;
  min-width: 0;
  position: relative;
}

.bar-value {
  color: #111318;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.15;
  min-height: 48rpx;
  text-align: center;
}

.bar-track {
  align-items: flex-end;
  background: linear-gradient(180deg, #fff8ec, #edf6ff);
  border-radius: 999rpx;
  display: flex;
  height: 210rpx;
  overflow: hidden;
  width: 28rpx;
}

.bar-fill {
  background: linear-gradient(180deg, #78a88b 0%, #b7d7c1 100%);
  border-radius: 999rpx;
  min-height: 4rpx;
  opacity: 0.92;
  width: 100%;
}

.bar-item text {
  color: #8b919c;
  font-size: 21rpx;
  line-height: 1.2;
  margin-top: 12rpx;
  min-height: 28rpx;
  text-align: center;
}
