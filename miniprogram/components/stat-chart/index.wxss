.chart {
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 36, 48, 0.06);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.chart-title {
  color: #1f2430;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
}

.bar-chart {
  align-items: flex-end;
  display: flex;
  height: 310rpx;
  justify-content: space-between;
}

.bar-item {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 100%;
  justify-content: flex-end;
  min-width: 0;
  position: relative;
}

.bar-value {
  color: #1f2430;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.15;
  min-height: 48rpx;
  text-align: center;
}

.bar-track {
  align-items: flex-end;
  background: #edf0f5;
  border-radius: 8rpx;
  display: flex;
  height: 210rpx;
  overflow: hidden;
  width: 34rpx;
}

.bar-fill {
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  width: 100%;
}

.bar-item text,
.line-item text {
  color: #7a8190;
  font-size: 22rpx;
  line-height: 1.2;
  margin-top: 12rpx;
  min-height: 28rpx;
  text-align: center;
}
