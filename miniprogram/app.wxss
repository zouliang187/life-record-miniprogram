page {
  --accent: #78a88b;
  --accent-soft: #eef7f1;
  --blue-soft: #edf6ff;
  --cream: #fff8ec;
  --warm: #fff3ee;
  --ink: #26312b;
  --ink-2: #526158;
  --muted: #8d9a92;
  --line: rgba(80, 96, 86, 0.1);
  --bg-color: #fbfaf7;
  --card-bg: rgba(255, 255, 255, 0.92);
  --surface: #ffffff;
  --exercise-color: #df8f83;
  --reading-color: #73aaa3;
  --sleep-color: #8aaed0;
  --english-color: #d7b866;
  --body-color: #9e8fc5;
  --shadow-soft: 0 18rpx 44rpx rgba(92, 106, 96, 0.1);
  --shadow-subtle: 0 10rpx 26rpx rgba(92, 106, 96, 0.06);
  background: linear-gradient(180deg, #fffdf8 0%, #fbfaf7 46%, #f3f7f1 100%);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  letter-spacing: 0;
  line-height: 1.5;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 34rpx 34rpx 58rpx;
}

.card {
  background: var(--card-bg);
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
  padding: 30rpx;
}

.section-title {
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0;
  margin: 34rpx 0 18rpx;
}

.muted {
  color: var(--muted);
}

.primary-button {
  background: linear-gradient(135deg, #78a88b 0%, #9ac8aa 100%);
  border-radius: 16rpx;
  box-shadow: 0 16rpx 34rpx rgba(120, 168, 139, 0.24);
  color: #ffffff;
  font-weight: 700;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(105, 126, 113, 0.12);
  border-radius: 16rpx;
  color: var(--ink);
}

.field {
  margin-bottom: 24rpx;
}

.label {
  color: var(--muted);
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input,
.textarea,
.picker-value {
  background: #f4f5f6;
  border: 1rpx solid rgba(105, 126, 113, 0.08);
  border-radius: 16rpx;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  width: 100%;
}

.textarea {
  height: 180rpx;
}

.tag {
  background: #f3f4f6;
  border-radius: 16rpx;
  color: var(--ink-2);
  display: inline-flex;
  font-size: 23rpx;
  padding: 8rpx 16rpx;
}
