.profile-card,
.goal-card,
.export-card,
.about {
  margin-bottom: 24rpx;
}

.avatar-row {
  align-items: center;
  display: flex;
  margin-bottom: 22rpx;
}

.avatar {
  align-items: center;
  background: #e9f8ef;
  border-radius: 8rpx;
  color: #07c160;
  display: flex;
  height: 112rpx;
  justify-content: center;
  margin-right: 20rpx;
  width: 112rpx;
}

.avatar-btn {
  font-size: 26rpx;
  line-height: 2.4;
  margin: 0;
}

.input,
.picker-value {
  margin-bottom: 18rpx;
}

.profile-row {
  align-items: center;
  background: #f2f4f7;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  min-height: 86rpx;
  padding: 0 22rpx;
}

.profile-row text {
  color: #424957;
  flex-shrink: 0;
  font-size: 27rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.profile-row input {
  color: #1f2430;
  flex: 1;
  font-size: 29rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: right;
}

.bmi-box {
  align-items: center;
  background: #f2f4f7;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #424957;
  display: grid;
  grid-template-columns: 1fr 104rpx 170rpx;
  font-weight: 700;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
}

.bmi-box.normal {
  background: #eef8f2;
  color: #07c160;
}

.bmi-box.thin {
  background: #fff0ec;
  color: #ee0a24;
}

.bmi-box.fat {
  background: #f2f4f7;
  color: #1f2430;
}

.bmi-value,
.bmi-status {
  font-size: 28rpx;
}

.bmi-status {
  text-align: center;
}

.bmi-range {
  font-size: 22rpx;
  text-align: right;
}

.goal-item {
  border-bottom: 1rpx solid #edf0f5;
  padding: 22rpx 0;
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-head,
.goal-title,
.goal-edit {
  align-items: center;
  display: flex;
}

.goal-head {
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.goal-title {
  color: #1f2430;
  font-size: 30rpx;
  font-weight: 700;
}

.goal-dot {
  border-radius: 50%;
  height: 18rpx;
  margin-right: 12rpx;
  width: 18rpx;
}

.goal-count {
  color: #7a8190;
  font-size: 25rpx;
}

.goal-progress {
  background: #edf0f5;
  border-radius: 8rpx;
  height: 18rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.goal-progress-fill {
  border-radius: 8rpx;
  height: 100%;
}

.goal-edit {
  color: #7a8190;
  font-size: 25rpx;
  justify-content: space-between;
}

.goal-edit input {
  background: #f2f4f7;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #1f2430;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 16rpx;
  text-align: right;
  width: 168rpx;
}

.action-button {
  font-size: 30rpx;
  line-height: 2.8;
  margin-bottom: 18rpx;
  width: 100%;
}

.export-card text {
  color: #424957;
  font-family: monospace;
  font-size: 22rpx;
  word-break: break-all;
}
