.growth-hero {
  background: linear-gradient(145deg, #ffffff 0%, #fff8ec 48%, #eef7f1 100%);
  color: #26312b;
  margin-bottom: 22rpx;
  padding: 34rpx 30rpx;
}

.growth-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.eyebrow {
  color: #9aa794;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.growth-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.role-trigger {
  position: relative;
}

.role-trigger::after {
  color: #9aa794;
  content: "▼";
  font-size: 18rpx;
  margin-left: 12rpx;
  vertical-align: middle;
}

.growth-subtitle {
  color: #6d7a72;
  font-size: 24rpx;
  line-height: 1.55;
  margin-top: 12rpx;
  max-width: 430rpx;
}

.hero-avatar {
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(120, 168, 139, 0.18);
  border-radius: 50%;
  display: flex;
  flex-shrink: 0;
  height: 142rpx;
  justify-content: center;
  overflow: hidden;
  text-align: center;
  width: 142rpx;
}

.insight-strip {
  background: rgba(255, 255, 255, 0.64);
  border-radius: 16rpx;
  display: grid;
  gap: 1rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 30rpx;
  overflow: hidden;
}

.insight-item {
  display: flex;
  flex-direction: column;
  padding: 18rpx 20rpx;
}

.insight-label {
  color: #8d9a92;
  font-size: 21rpx;
}

.insight-value {
  color: #26312b;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 4rpx;
}

.badge-panel {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 24rpx;
}

.badge-item {
  align-items: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, #f7fbf8 100%);
  border: 1rpx solid rgba(17, 19, 24, 0.055);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(17, 19, 24, 0.045);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 164rpx;
  padding: 18rpx 14rpx;
  text-align: center;
}

.badge-icon {
  align-items: center;
  background: #eef7f1;
  border-radius: 16rpx;
  color: #5f9573;
  display: flex;
  font-size: 24rpx;
  font-weight: 900;
  height: 54rpx;
  justify-content: center;
  margin-bottom: 14rpx;
  width: 54rpx;
}

.muted-icon {
  background: #fff8ec;
  color: #9b8141;
}

.badge-title {
  color: #26312b;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-desc {
  color: #8f96a3;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.profile-card,
.goal-card,
.export-card,
.about {
  margin-bottom: 24rpx;
}

.profile-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-bottom: 18rpx;
}

.half-row {
  margin-bottom: 0;
  min-width: 0;
}

.input,
.picker-value {
  margin-bottom: 18rpx;
}

.profile-row {
  align-items: center;
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
  min-height: 86rpx;
  padding: 0 22rpx;
}

.profile-grid .picker-value {
  align-items: center;
  display: flex;
  margin-bottom: 0;
}

.goal-section-title {
  color: #4f735f;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.profile-row text {
  color: #424957;
  flex-shrink: 0;
  font-size: 27rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.profile-row input {
  color: #26312b;
  flex: 1;
  font-size: 29rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: right;
}

.bmi-box {
  align-items: center;
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #424957;
  display: grid;
  grid-template-columns: 1fr 104rpx 170rpx;
  font-weight: 700;
  gap: 12rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
}

.bmi-box.normal {
  background: #f2f6f3;
  color: #4f735f;
}

.bmi-box.thin {
  background: #fff0ec;
  color: #ee0a24;
}

.bmi-box.fat {
  background: #f2f4f7;
  color: #526158;
}

.bmi-value,
.bmi-status {
  font-size: 28rpx;
}

.bmi-status {
  text-align: center;
}

.bmi-range {
  font-size: 22rpx;
  text-align: right;
}

.goal-item {
  border-bottom: 1rpx solid #edf0f5;
  padding: 22rpx 0;
}

.goal-item:last-child {
  border-bottom: none;
}

.goal-head,
.goal-title,
.goal-edit {
  align-items: center;
  display: flex;
}

.goal-head {
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.goal-title {
  color: #26312b;
  font-size: 30rpx;
  font-weight: 700;
}

.goal-dot {
  border-radius: 50%;
  height: 18rpx;
  margin-right: 12rpx;
  width: 18rpx;
}

.goal-count {
  color: #7a8190;
  font-size: 25rpx;
}

.goal-progress {
  background: #edf0f3;
  border-radius: 16rpx;
  height: 18rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.goal-progress-fill {
  border-radius: 16rpx;
  height: 100%;
}

.goal-edit {
  color: #7a8190;
  font-size: 25rpx;
  justify-content: space-between;
}

.goal-edit input {
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #26312b;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 16rpx;
  text-align: right;
  width: 168rpx;
}

.action-button {
  font-size: 30rpx;
  line-height: 2.8;
  margin-bottom: 18rpx;
  width: 100%;
}

.export-card text {
  color: #424957;
  font-family: monospace;
  font-size: 22rpx;
  word-break: break-all;
}
