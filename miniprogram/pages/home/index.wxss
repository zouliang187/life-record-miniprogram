.date-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-btn {
  margin: 0;
  font-size: 22rpx;
  color: #1677ff;
  border: 1rpx solid #c6dcff;
  background: #fff;
}

.date-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2b3d;
  padding: 8rpx 20rpx;
}

.form {
  padding-bottom: 20rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #415063;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  min-height: 72rpx;
  border: 1rpx solid #dce3ed;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  background: #fff;
}

.textarea {
  width: 100%;
  height: 140rpx;
  border: 1rpx solid #dce3ed;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f0f3f9;
  color: #4f5f74;
  font-size: 24rpx;
}

.chip-active {
  background: #dcecff;
  color: #1677ff;
}

.tips {
  color: #7e8796;
  font-size: 24rpx;
}

.switch-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-field .label {
  margin: 0;
}

.disabled {
  opacity: 0.5;
}

.submit {
  margin-top: 16rpx;
  background: #1677ff;
  color: #fff;
}
