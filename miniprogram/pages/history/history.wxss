.calendar-card,
.day-card,
.list-card {
  margin-bottom: 24rpx;
}

.month-header {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-bottom: 26rpx;
}

.month-btn {
  align-items: center;
  display: flex;
  font-size: 24rpx;
  font-weight: 800;
  gap: 4rpx;
  height: 72rpx;
  justify-content: center;
  line-height: 1;
  margin: 0;
  padding: 0;
  width: 94rpx;
}

.month-btn text:first-child,
.month-btn text:last-child {
  white-space: nowrap;
}

.prev-btn text:last-child,
.next-btn text:first-child {
  font-size: 36rpx;
  line-height: 1;
}

.month-title {
  align-items: center;
  display: flex;
  flex-direction: column;
  width: 100%;
}

.year-text {
  color: #26312b;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
}

.month-line {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
  width: 100%;
}

.month-text {
  color: #4f735f;
  font-size: 34rpx;
  font-weight: 900;
  margin: 0 16rpx;
  min-width: 88rpx;
  text-align: center;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
}

.week-row {
  color: #8d9a92;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.day {
  align-items: center;
  border-radius: 16rpx;
  display: flex;
  height: 72rpx;
  justify-content: center;
  margin: 4rpx;
}

.day.blank {
  background: transparent;
}

.day.has-record {
  background: #f1f3ef;
  color: #5f9573;
}

.day.selected {
  background: linear-gradient(135deg, #78a88b 0%, #b7d7c1 100%);
  color: #ffffff;
  font-weight: 700;
}

.record-line {
  color: #424957;
  margin: 12rpx 0;
}

.empty {
  color: #a0a7b5;
  padding: 24rpx 0;
  text-align: center;
}

.filters {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.filter {
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  color: #8f96a3;
  flex-shrink: 0;
  padding: 14rpx 24rpx;
}

.filter.active {
  background: #eef7f1;
  color: #5f9573;
}

.list-item {
  border-bottom: 1rpx solid #edf0f5;
  padding: 20rpx 0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-title {
  color: #26312b;
  font-weight: 700;
  margin-bottom: 8rpx;
}
