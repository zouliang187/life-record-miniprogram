.calendar-card,
.day-card,
.list-card {
  margin-bottom: 24rpx;
}

.month-header {
  align-items: center;
  display: flex;
  font-size: 32rpx;
  font-weight: 700;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.month-btn {
  font-size: 24rpx;
  line-height: 2.2;
  margin: 0;
  width: 128rpx;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
}

.week-row {
  color: #7a8190;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.day {
  align-items: center;
  border-radius: 8rpx;
  display: flex;
  height: 72rpx;
  justify-content: center;
  margin: 4rpx;
}

.day.blank {
  background: transparent;
}

.day.has-record {
  background: #e9f8ef;
  color: #07c160;
}

.day.selected {
  background: #07c160;
  color: #ffffff;
  font-weight: 700;
}

.record-line {
  color: #424957;
  margin: 12rpx 0;
}

.empty {
  color: #a0a7b5;
  padding: 24rpx 0;
  text-align: center;
}

.filters {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.filter {
  background: #ffffff;
  border-radius: 8rpx;
  color: #7a8190;
  flex-shrink: 0;
  padding: 14rpx 24rpx;
}

.filter.active {
  background: #07c160;
  color: #ffffff;
}

.list-item {
  border-bottom: 1rpx solid #edf0f5;
  padding: 20rpx 0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-title {
  color: #1f2430;
  font-weight: 700;
  margin-bottom: 8rpx;
}
