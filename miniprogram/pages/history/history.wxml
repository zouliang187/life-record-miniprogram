<view class="page history-page">
  <view class="calendar-card card">
    <view class="month-header">
      <view class="month-title">
        <picker mode="selector" range="{{years}}" value="{{yearIndex}}" bindchange="onYearChange">
          <text class="year-text">{{year}}年</text>
        </picker>
        <view class="month-line">
          <button class="ghost-button month-btn prev-btn" data-offset="-1" bindtap="onMonthShift">
            <text>上月</text><text>‹</text>
          </button>
          <text class="month-text">{{month}}月</text>
          <button class="ghost-button month-btn next-btn" data-offset="1" bindtap="onMonthShift">
            <text>›</text><text>下月</text>
          </button>
        </view>
      </view>
    </view>
    <view class="week-row">
      <text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text>
    </view>
    <view class="calendar-grid">
      <view
        wx:for="{{calendar}}"
        wx:key="date"
        class="day {{item.isBlank ? 'blank' : ''}} {{item.hasRecord ? 'has-record' : ''}} {{item.selected ? 'selected' : ''}}"
        data-date="{{item.date}}"
        bindtap="onDateTap"
      >{{item.day}}</view>
    </view>
  </view>

  <view class="card day-card">
    <view class="section-title">{{selectedDate}} 记录</view>
    <view wx:if="{{dayRecords.length === 0}}" class="empty">当天暂无记录</view>
    <view wx:for="{{dayRecords}}" wx:key="type" class="record-line">• {{item.typeName}} {{item.summary}}</view>
  </view>

  <view class="filters">
    <view
      wx:for="{{filters}}"
      wx:key="type"
      class="filter {{filterType === item.type ? 'active' : ''}}"
      data-type="{{item.type}}"
      bindtap="onFilterTap"
    >{{item.name}}</view>
  </view>

  <view class="card list-card">
    <view class="section-title">记录列表</view>
    <view wx:if="{{listRecords.length === 0}}" class="empty">暂无记录</view>
    <view wx:for="{{listRecords}}" wx:key="timestamp" class="list-item">
      <view>
        <view class="list-title">{{item.date}} {{item.typeName}}</view>
        <view class="muted">{{item.summary}}</view>
      </view>
    </view>
  </view>
</view>
