.range-tabs {
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  padding: 6rpx;
  margin-bottom: 18rpx;
}

.tab {
  flex: 1;
  text-align: center;
  line-height: 64rpx;
  border-radius: 12rpx;
  color: #5f6b7d;
}

.active {
  background: #1677ff;
  color: #fff;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(25, 40, 70, 0.06);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.line {
  color: #4c586a;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.progress {
  width: 100%;
  height: 12rpx;
  background: #edf1f8;
  border-radius: 999rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.progress-inner {
  height: 100%;
  background: #1677ff;
}

.empty {
  text-align: center;
  color: #8893a2;
  margin-top: 60rpx;
}
