.range-tabs {
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(105, 126, 113, 0.12);
  border-radius: 16rpx;
  display: flex;
  margin-bottom: 24rpx;
  padding: 8rpx;
}

.range-tab {
  border-radius: 12rpx;
  color: #8d9a92;
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
}

.range-tab.active {
  background: #eef7f1;
  color: #5f9573;
  font-weight: 700;
}

.overview {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-bottom: 24rpx;
}

.overview-item {
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-sizing: border-box;
  min-height: 112rpx;
  padding: 20rpx;
}

.overview-item:first-child {
  background: linear-gradient(135deg, #eef7f1 0%, #edf6ff 100%);
  grid-column: span 2;
  min-height: 154rpx;
}

.overview-item:first-child .overview-title,
.overview-item:first-child .overview-value {
  color: #4f735f !important;
}

.overview-title {
  color: #8d9a92;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.overview-value {
  color: #1f2430;
  font-size: 34rpx;
  font-weight: 800;
}

.heatmap-card {
  margin-bottom: 24rpx;
}

.heatmap {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(7, 1fr);
}

.week-header {
  color: #8d9a92;
  display: grid;
  font-size: 22rpx;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 10rpx;
  text-align: center;
}

.heat-cell {
  align-items: center;
  background: #fffdf8;
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #8d9a92;
  display: flex;
  flex-direction: column;
  font-size: 20rpx;
  height: 86rpx;
  justify-content: center;
}

.blank-cell {
  background: transparent;
}

.level-1 {
  background: #f4eeee;
  color: #9d6a67;
}

.level-2 {
  background: #f1f3ef;
  color: #6f927d;
}

.level-3 {
  background: #f5f0e4;
  color: #9b8141;
}

.level-4 {
  background: #eef7f1;
  color: #4f735f;
}

.month-record {
  background: #efe4e4;
  color: #9d6a67;
}

.scroll-chart-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-shadow: 0 14rpx 36rpx rgba(17, 19, 24, 0.06);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 22rpx 0 22rpx 22rpx;
}

.scroll-chart-title {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  padding-right: 22rpx;
}

.scroll-chart-title text:first-child {
  color: #1f2430;
  font-size: 30rpx;
  font-weight: 700;
}

.chart-scroll {
  width: 100%;
}

.body-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(105, 126, 113, 0.1);
  border-radius: 16rpx;
  box-shadow: 0 14rpx 36rpx rgba(17, 19, 24, 0.06);
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 24rpx 0 24rpx 24rpx;
}

.body-card-head {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
  padding-right: 24rpx;
  margin-bottom: 12rpx;
}

.body-title {
  color: #1f2430;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.body-range-tabs {
  background: #fff8ec;
  border-radius: 16rpx;
  display: flex;
  flex-shrink: 0;
  padding: 4rpx;
}

.body-range-tab {
  border-radius: 12rpx;
  color: #8d9a92;
  font-size: 22rpx;
  padding: 8rpx 12rpx;
}

.body-range-tab.active {
  background: #eef7f1;
  color: #5f9573;
  font-weight: 700;
}
