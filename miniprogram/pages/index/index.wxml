<view class="page home-page">
  <view class="hero">
    <view>
      <view class="date">{{dateText}}</view>
      <view class="week">{{weekText}}</view>
    </view>
    <view class="today-score">{{completedCount}}/4</view>
  </view>

  <view class="summary card">
    <view class="summary-main">连续打卡</view>
    <view class="streak">🔥 {{streak}}天</view>
    <button class="primary-button quick-button" bindtap="onQuickRecord">今日记录</button>
  </view>

  <view class="section-title">今日状态</view>
  <record-card
    wx:for="{{cards}}"
    wx:key="type"
    type="{{item.type}}"
    title="{{item.title}}"
    icon="{{item.icon}}"
    color="{{item.color}}"
    completed="{{item.completed}}"
    status-text="{{item.statusText}}"
    detail-text="{{item.detailText}}"
    bind:tapcard="onCardTap"
  />
</view>
